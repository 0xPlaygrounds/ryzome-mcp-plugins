{
	"id": "openclaw-ryzome",
	"name": "Ryzome Canvas OpenClaw Plugin",
	"description": "Create Ryzome canvases from plans and research",
	"version": "0.4.2",
	"activation": {
		"onCommands": ["ryzome"]
	},
	"contracts": {
		"tools": [
			"create_ryzome_canvas",
			"create_ryzome_document",
			"create_ryzome_plan",
			"create_ryzome_research",
			"get_ryzome_canvas",
			"get_ryzome_document",
			"list_ryzome_canvases",
			"list_ryzome_documents",
			"save_ryzome_node_to_library",
			"update_ryzome_document",
			"upload_ryzome_image"
		]
	},
	"configSchema": {
		"type": "object",
		"additionalProperties": false,
		"properties": {
			"apiKey": {
				"type": "string"
			},
			"apiUrl": {
				"type": "string",
				"default": "https://api.ryzome.ai"
			},
			"appUrl": {
				"type": "string",
				"default": "https://ryzome.ai"
			}
		},
		"required": []
	},
	"uiHints": {
		"apiKey": {
			"label": "Ryzome API Key",
			"sensitive": true,
			"placeholder": "rz_...",
			"help": "Ryzome API key (or use ${RYZOME_OPENCLAW_API_KEY})"
		},
		"apiUrl": {
			"label": "Ryzome API URL",
			"placeholder": "https://api.ryzome.ai"
		},
		"appUrl": {
			"label": "Ryzome App URL",
			"placeholder": "https://ryzome.ai"
		}
	}
}
