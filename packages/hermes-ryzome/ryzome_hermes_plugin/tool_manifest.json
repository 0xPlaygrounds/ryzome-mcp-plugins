  {
    "name": "save_ryzome_node_to_library",
    "description": "Promote an existing canvas node's backing document into the library.",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "canvas_id": {
          "type": "string",
          "description": "The ID of the canvas containing the node"
        },
        "node_id": {
          "type": "string",
          "description": "The ID of the node to save to the library"
        }
      },
      "required": [
        "canvas_id",
        "node_id"
      ],
      "additionalProperties": false
    }
  },
  {
    "name": "upload_ryzome_image",
    "description": "Upload an image from a URL to an existing Ryzome canvas. Fetches the image, uploads it to storage, and creates an image node on the canvas.",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "canvas_id": {
          "type": "string",
          "description": "The ID of the canvas to add the image to"
        },
        "image_url": {
          "type": "string",
          "format": "uri",
          "description": "Public URL of the image to upload"
        },
        "title": {
          "description": "Title for the image node",
          "type": "string"
        },
        "x": {
          "description": "X position on canvas (defaults to 0)",
          "type": "number"
        },
        "y": {
          "description": "Y position on canvas (defaults to 0)",
          "type": "number"
        },
        "width": {
          "description": "Node width in pixels (defaults to 320)",
          "type": "number"
        },
        "height": {
          "description": "Node height in pixels (defaults to 240)",
          "type": "number"
        },
        "color": {
          "description": "Node color as hex (e.g. '#FF6B6B')",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        }
      },
      "required": [
        "canvas_id",
        "image_url"
      ],
      "additionalProperties": false
    }
  }
]
