{
	"name": "@ryzome-ai/canvas-layout-ts",
	"version": "0.2.0",
	"description": "Ryzome canvas layout — compound-graph placement for nodes, edges, and groups via elkjs",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@10.31.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/0xPlaygrounds/ryzome-mcp-plugins.git",
		"directory": "packages/canvas-layout-ts"
	},
	"homepage": "https://github.com/0xPlaygrounds/ryzome-mcp-plugins/tree/main/packages/canvas-layout-ts",
	"bugs": {
		"url": "https://github.com/0xPlaygrounds/ryzome-mcp-plugins/issues"
	},
	"keywords": [
		"ryzome",
		"canvas",
		"layout",
		"elkjs",
		"graph"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint . && tsc --noEmit",
		"lint:check": "biome lint --diagnostic-level=error .",
		"format": "biome format --write .",
		"format:check": "biome format ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.4.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"elkjs": "^0.10.0"
	}
}
