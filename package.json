{
	"private": true,
	"name": "ryzome-openclaw-workspace",
	"packageManager": "pnpm@10.31.0",
	"scripts": {
		"test": "pnpm --filter './packages/*' -r --if-present test",
		"test:integration": "pnpm --filter './packages/*' -r --if-present test:integration",
		"typecheck": "pnpm -r --if-present typecheck",
		"lint": "pnpm -r --if-present lint",
		"lint:check": "pnpm -r --if-present lint:check",
		"format": "pnpm -r --if-present format",
		"format:check": "pnpm -r --if-present format:check",
		"build": "pnpm -r --if-present build"
	}
}
