{
	"name": "@ryzome-ai/openclaw-ryzome",
	"version": "0.3.2",
	"description": "Ryzome Canvas OpenClaw Plugin",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@10.31.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/0xPlaygrounds/ryzome-mcp-plugins.git",
		"directory": "packages/openclaw-ryzome"
	},
	"homepage": "https://github.com/0xPlaygrounds/ryzome-mcp-plugins/tree/main/packages/openclaw-ryzome",
	"bugs": {
		"url": "https://github.com/0xPlaygrounds/ryzome-mcp-plugins/issues"
	},
	"keywords": [
		"openclaw",
		"ryzome",
		"plugin",
		"canvas",
		"agent"
	],
	"openclaw": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"src/*.ts",
		"openclaw.plugin.json"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"test": "vitest run",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:watch": "vitest watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint . && tsc --noEmit",
		"lint:check": "biome lint --diagnostic-level=error .",
		"format": "biome format --write .",
		"format:check": "biome format ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.4.0",
		"openclaw": "^2026.3.8",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@ryzome-ai/ryzome-core": "workspace:*",
		"@sinclair/typebox": "^0.34.48",
		"chalk": "^5.6.2",
		"zod": "^4.3.6"
	}
}
